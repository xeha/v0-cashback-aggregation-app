# Timeweb Object Storage public URL (required). Example:
# ASSETS_URL=https://fcdc8bee-4045-49ca-8869-3f22cd730eb5.s3.twcstorage.ru
ASSETS_URL=
MISTRAL_API_KEY=your_mistral_api_key
# Vision OCR can take 30–90s on large screenshots; httpx default is only 5s.
MISTRAL_REQUEST_TIMEOUT_SEC=120
# Downscale phone screenshots before sending to Mistral (reduces SSL/upload failures).
OCR_MAX_IMAGE_DIMENSION=1200
OCR_JPEG_QUALITY=80
MISTRAL_VISION_MODEL=pixtral-12b-2409
MISTRAL_CLASSIFIER_MODEL=mistral-large-latest
ALLOWED_ORIGINS=https://your-app.vercel.app
SENTENCE_TRANSFORMER_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CATEGORY_PARENT_THRESHOLD=0.55
CATEGORY_LEAF_THRESHOLD=0.60
CATEGORY_LLM_FALLBACK=true
RETAILER_ENRICH_ENABLED=true
MISTRAL_RETAILER_MODEL=mistral-small-latest
MARKET_SPLIT_MAP_LLM_ENABLED=true
MARKET_MAP_BATCH_SIZE=30
MARKET_MAP_CONFIDENCE_MIN=0.5
# Path to source markdown for hierarchy builder script
REFERENCE_HIERARCHY_MD=
