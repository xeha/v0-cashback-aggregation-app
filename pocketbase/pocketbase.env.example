# Скопируйте в корень проекта как .env.pocketbase (файл в .gitignore):
#   cp pocketbase/pocketbase.env.example .env.pocketbase
#
# Загрузка (не используйте source — пароль может содержать спецсимволы):
#   python3 scripts/setup_pocketbase_phase1.py
#   python3 scripts/setup_pocketbase.py --import-catalog

POCKETBASE_URL=https://pb.cashbackbrain.ru
POCKETBASE_ADMIN_EMAIL=admin@cashbackbrain.ru
POCKETBASE_ADMIN_PASSWORD="ваш_пароль"

# false — если на Mac SSL verify падает на Let's Encrypt
POCKETBASE_SSL_VERIFY=false
