# Copy to project root as .env.dokploy (gitignored):
#   cp dokploy.env.example .env.dokploy
#
# Deploy full stack:
#   set -a && source .env.dokploy && set +a
#   python3 scripts/deploy_environment_dokploy.py development
#   python3 scripts/deploy_environment_dokploy.py production

DOKPLOY_URL=https://dokploy.cashbackbrain.ru
DOKPLOY_API_KEY=вставьте_ключ_сюда
DOKPLOY_PROJECT_NAME=CashbackBrain

# Optional: DOKPLOY_GITHUB_ID=...

# --- Development (ветка dev) ---
# DOKPLOY_TARGET=development
# FRONTEND_DOMAIN=dev.cashbackbrain.ru
# FASTAPI_DOMAIN=api-dev.cashbackbrain.ru
# POCKETBASE_DOMAIN=pb-dev.cashbackbrain.ru

# --- Production (ветка main) ---
# DOKPLOY_TARGET=production
# FRONTEND_DOMAIN=cashbackbrain.ru
# FASTAPI_DOMAIN=api.cashbackbrain.ru
# POCKETBASE_DOMAIN=pb.cashbackbrain.ru
