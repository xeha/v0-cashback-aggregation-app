# Frontend (Next.js)
# Local dev on Mac — backend URL for Next.js proxy (default http://127.0.0.1:8000).
# Phone over Wi-Fi: open http://<Mac-IP>:3000 — API is proxied automatically, no LAN URL needed.
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
# DEV_LAN_HOST=192.168.3.57  # optional; allows Next dev from phone (ipconfig getifaddr en0)
# Logos from Timeweb S3 (dev + prod). If unset, falls back to public/logos/ locally.
# NEXT_PUBLIC_ASSETS_URL=https://fcdc8bee-4045-49ca-8869-3f22cd730eb5.s3.twcstorage.ru
# PocketBase (auth + saved_matrices). See pocketbase/DOKPLOY.md
# NEXT_PUBLIC_POCKETBASE_URL=https://pb.cashbackbrain.ru
# NEXT_PUBLIC_BACKEND_URL=https://api.cashbackbrain.ru

# Backend (FastAPI) — copy to backend/.env
# MISTRAL_API_KEY=your_mistral_api_key
# MISTRAL_VISION_MODEL=pixtral-12b-2409
# ALLOWED_ORIGINS=https://your-app.vercel.app
# CATEGORY_MAP_THRESHOLD=0.45
# SENTENCE_TRANSFORMER_MODEL=paraphrase-multilingual-MiniLM-L12-v2
