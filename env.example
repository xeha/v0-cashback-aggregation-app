# Frontend (Next.js)
# Local dev: Next.js проксирует /api/* → FastAPI на :8000 (см. next.config.mjs).
# Запуск: в одном терминале `cd backend && uvicorn main:app --reload --port 8000`,
#         в другом `npm run dev`.
# Прямой URL (опционально, для OCR с большими телами):
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
# DEV_LAN_HOST=192.168.3.57  # optional; allows Next dev from phone (ipconfig getifaddr en0)
# Logos + catalogs: Timeweb CDN (источник — S3-бакет fcdc8bee-...).
NEXT_PUBLIC_ASSETS_URL=https://1mh89t7nqb.cdn.twcstorage.ru
# PocketBase (auth + saved_matrices). See pocketbase/DOKPLOY.md
# NEXT_PUBLIC_POCKETBASE_URL=https://pb.cashbackbrain.ru
# NEXT_PUBLIC_BACKEND_URL=https://api.cashbackbrain.ru
# NEXT_PUBLIC_APP_URL=https://cashbackbrain.ru
# Email verification after register (set false for local E2E without SMTP)
# NEXT_PUBLIC_AUTH_REQUIRE_EMAIL_VERIFICATION=true
# Skip DNS MX check via FastAPI (только E2E/CI без бэкенда)
# NEXT_PUBLIC_AUTH_SKIP_MX_CHECK=true

# Backend (FastAPI) — copy to backend/.env
# MISTRAL_API_KEY=your_mistral_api_key
# MISTRAL_VISION_MODEL=pixtral-12b-2409
# ALLOWED_ORIGINS=https://your-app.vercel.app
# CATEGORY_MAP_THRESHOLD=0.45
# SENTENCE_TRANSFORMER_MODEL=paraphrase-multilingual-MiniLM-L12-v2
