# Timeweb Cloud API (панель → API и Terraform → выпустить токен)
# Скопируйте в корень проекта (файл в .gitignore):
#   cp timeweb.env.example .env.timeweb
#   # вставьте токен в .env.timeweb
#
# Используется для управления CDN, S3, DNS через api.timeweb.cloud
# НЕ путать с ключами доступа к бакету (R2_* в .env.s3) и Dokploy (DOKPLOY_API_KEY в .env.dokploy)

TIMEWEB_CLOUD_TOKEN=вставьте_токен_сюда

# VPS CashbackBrain (опционально — иначе ищется по имени)
# TIMEWEB_SERVER_ID=8455605
# TIMEWEB_SERVER_NAME=CashbackBrain

# Опционально — если понадобится в скриптах
# TIMEWEB_CDN_RESOURCE_ID=
# TIMEWEB_S3_BUCKET_ID=fcdc8bee-4045-49ca-8869-3f22cd730eb5
